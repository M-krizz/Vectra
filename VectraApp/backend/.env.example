# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name

# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# JWT  ⚠️  CHANGE THESE SECRETS IN PRODUCTION
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─────────────────────────────────────────────────────────────────────────────
# OTP settings
# ─────────────────────────────────────────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=30
# Set to a fixed code in development so you don't need real SMS/email
OTP_DEV_BYPASS_CODE=000000

# ─────────────────────────────────────────────────────────────────────────────
# Fast2SMS  (preferred SMS provider for India, BulkV2 OTP route)
#   ⚠️  Never commit your actual key — store it only here in .env (gitignored)
# ─────────────────────────────────────────────────────────────────────────────
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# Twilio  (fallback SMS provider when FAST2SMS_API_KEY is not set)
# ─────────────────────────────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─────────────────────────────────────────────────────────────────────────────
# SMTP — Email OTP  (Gmail example — use an App Password, not your real password)
#   Gmail: Enable 2FA → Google Account → Security → App Passwords → generate one
#   ⚠️  Never commit your actual credentials here
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_16_char_app_password_here
SMTP_FROM=your_gmail_address@gmail.com
SMTP_EMAIL_ENABLED=true

# ─────────────────────────────────────────────────────────────────────────────
# CORS  (comma-separated origins for production)
# ─────────────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200
